<?xml version="1.0" encoding="UTF-8"?>
<!--
  LEARNING: team_performance.jrxml
  Match history (detail band) + stats and tournaments (summary band).
  See docs/jasper-learning.md for the full walkthrough.
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd
              http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd"
              name="team_performance"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              whenResourceMissingType="Empty">

    <!-- LEARNING: SubDataset schema for match table rows (TeamPerformanceDTO) -->
    <subDataset name="MatchHistoryDataset">
        <field name="year" class="java.lang.Integer"/>
        <field name="matchDate" class="java.time.LocalDate"/>
        <field name="opponent" class="java.lang.String"/>
        <field name="opponentFlagUrl" class="java.lang.String"/>
        <field name="goalsFor" class="java.lang.Integer"/>
        <field name="goalsAgainst" class="java.lang.Integer"/>
        <field name="result" class="java.lang.String"/>
        <field name="stage" class="java.lang.String"/>
        <field name="stadium" class="java.lang.String"/>
    </subDataset>

    <!-- LEARNING: SubDataset schema for tournament table rows (TournamentSummaryDTO) -->
    <subDataset name="TournamentDataset">
        <field name="year" class="java.lang.Integer"/>
        <field name="hostCountry" class="java.lang.String"/>
        <field name="tournamentStart" class="java.time.LocalDate"/>
        <field name="tournamentEnd" class="java.time.LocalDate"/>
        <field name="role" class="java.lang.String"/>
        <field name="hostFlagUrl" class="java.lang.String"/>
    </subDataset>

    <parameter name="teamName" class="java.lang.String"/>
    <parameter name="teamFlagUrl" class="java.lang.String"/>
    <parameter name="reportDate" class="java.time.LocalDate"/>
    <parameter name="totalWorldCups" class="java.lang.Integer"/>
    <parameter name="totalMatches" class="java.lang.Integer"/>
    <parameter name="wins" class="java.lang.Integer"/>
    <parameter name="losses" class="java.lang.Integer"/>
    <parameter name="draws" class="java.lang.Integer"/>
    <parameter name="goalsScored" class="java.lang.Integer"/>
    <parameter name="goalsConceded" class="java.lang.Integer"/>
    <parameter name="goalDifference" class="java.lang.Integer"/>
    <parameter name="matchDataSource" class="net.sf.jasperreports.engine.JRDataSource"/>
    <parameter name="tournamentDataSource" class="net.sf.jasperreports.engine.JRDataSource"/>

    <title>
        <band height="140">
            <image scaleImage="FillFrame" onErrorType="Blank">
                <reportElement x="0" y="15" width="70" height="45"/>
                <imageExpression><![CDATA[$P{teamFlagUrl}]]></imageExpression>
            </image>
            <staticText>
                <reportElement x="80" y="15" width="475" height="35" forecolor="#1a237e"/>
                <textElement textAlignment="Center">
                    <font size="22" isBold="true" fontName="DejaVu Sans"/>
                </textElement>
                <text><![CDATA[FIFA World Cup Performance Report]]></text>
            </staticText>
            <textField>
                <reportElement x="80" y="52" width="475" height="28" forecolor="#0d47a1"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true" fontName="DejaVu Sans"/>
                </textElement>
                <textFieldExpression><![CDATA["Team: " + $P{teamName}]]></textFieldExpression>
            </textField>
            <textField pattern="MMMM dd, yyyy">
                <reportElement x="350" y="95" width="205" height="20" forecolor="#666666"/>
                <textElement textAlignment="Right">
                    <font size="10" fontName="DejaVu Sans"/>
                </textElement>
                <textFieldExpression><![CDATA["Generated: " + $P{reportDate}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="130" width="555" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#1a237e"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <!-- LEARNING: Detail runs once (JREmptyDataSource). Match table reads $P{matchDataSource}. -->
    <detail>
        <band height="280" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="5" width="555" height="22" forecolor="#1a237e"/>
                <textElement>
                    <font size="14" isBold="true" fontName="DejaVu Sans"/>
                </textElement>
                <text><![CDATA[Match History]]></text>
            </staticText>

            <componentElement>
                <reportElement x="0" y="30" width="555" height="240" isPrintWhenDetailOverflows="true"/>
                <jr:table xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components">
                    <datasetRun subDataset="MatchHistoryDataset">
                        <dataSourceExpression><![CDATA[$P{matchDataSource}]]></dataSourceExpression>
                    </datasetRun>

                    <jr:column width="38">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="38" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Flag]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <image scaleImage="FillFrame" onErrorType="Blank">
                                <reportElement x="4" y="2" width="30" height="18"/>
                                <imageExpression><![CDATA[$F{opponentFlagUrl}]]></imageExpression>
                            </image>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="42">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="42" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Year]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="42" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{year}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="72">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="72" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Date]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField pattern="yyyy-MM-dd">
                                <reportElement x="0" y="0" width="72" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{matchDate}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="95">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="95" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Opponent]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="95" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{opponent}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="48">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="48" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Score]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="48" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{goalsFor} + " - " + $F{goalsAgainst}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="48">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="48" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Result]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="48" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{result}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="95">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="95" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Stage]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="95" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{stage}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="117">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="117" height="26" mode="Opaque" backcolor="#e8eaf6"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Stadium]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="117" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{stadium}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>
                </jr:table>
            </componentElement>
        </band>
    </detail>

    <summary>
        <band height="320" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="10" width="555" height="25" forecolor="#1a237e"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true" fontName="DejaVu Sans"/>
                </textElement>
                <text><![CDATA[Overall Statistics]]></text>
            </staticText>

            <staticText>
                <reportElement x="30" y="45" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Total World Cups:]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="45" width="80" height="20"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{totalWorldCups}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="45" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Total Matches:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="45" width="80" height="20"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{totalMatches}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="30" y="70" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Wins:]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="70" width="80" height="20" forecolor="#2e7d32"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{wins}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="70" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Losses:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="70" width="80" height="20" forecolor="#c62828"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{losses}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="30" y="95" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Draws:]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="95" width="80" height="20" forecolor="#f57c00"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{draws}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="95" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Goal Difference:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="95" width="80" height="20"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{goalDifference}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="30" y="120" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Goals Scored:]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="120" width="80" height="20"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{goalsScored}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="120" width="120" height="20"/>
                <textElement><font size="11" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Goals Conceded:]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="120" width="80" height="20"/>
                <textElement><font size="11" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$P{goalsConceded}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="155" width="555" height="22" forecolor="#1a237e"/>
                <textElement>
                    <font size="14" isBold="true" fontName="DejaVu Sans"/>
                </textElement>
                <text><![CDATA[Tournament Participation]]></text>
            </staticText>

            <componentElement>
                <reportElement x="0" y="180" width="555" height="130" isPrintWhenDetailOverflows="true"/>
                <jr:table xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components">
                    <datasetRun subDataset="TournamentDataset">
                        <dataSourceExpression><![CDATA[$P{tournamentDataSource}]]></dataSourceExpression>
                    </datasetRun>

                    <jr:column width="38">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="38" height="26" mode="Opaque" backcolor="#e3f2fd"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Host]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <image scaleImage="FillFrame" onErrorType="Blank">
                                <reportElement x="4" y="2" width="30" height="18"/>
                                <imageExpression><![CDATA[$F{hostFlagUrl}]]></imageExpression>
                            </image>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="50">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="50" height="26" mode="Opaque" backcolor="#e3f2fd"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Year]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="50" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{year}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="110">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="110" height="26" mode="Opaque" backcolor="#e3f2fd"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Host Country]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="110" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{hostCountry}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="95">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="95" height="26" mode="Opaque" backcolor="#e3f2fd"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Start]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField pattern="MMM dd, yyyy">
                                <reportElement x="0" y="0" width="95" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{tournamentStart}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="95">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="95" height="26" mode="Opaque" backcolor="#e3f2fd"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[End]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField pattern="MMM dd, yyyy">
                                <reportElement x="0" y="0" width="95" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{tournamentEnd}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>

                    <jr:column width="167">
                        <jr:columnHeader height="26" rowSpan="1">
                            <staticText>
                                <reportElement x="0" y="0" width="167" height="26" mode="Opaque" backcolor="#e3f2fd"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement textAlignment="Center" verticalAlignment="Middle">
                                    <font size="9" isBold="true" fontName="DejaVu Sans"/>
                                </textElement>
                                <text><![CDATA[Team Role]]></text>
                            </staticText>
                        </jr:columnHeader>
                        <jr:detailCell height="22">
                            <textField>
                                <reportElement x="0" y="0" width="167" height="22"/>
                                <box><pen lineWidth="0.5"/></box>
                                <textElement verticalAlignment="Middle">
                                    <font size="8" fontName="DejaVu Sans"/>
                                </textElement>
                                <textFieldExpression><![CDATA[$F{role}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>
                </jr:table>
            </componentElement>
        </band>
    </summary>
</jasperReport>
