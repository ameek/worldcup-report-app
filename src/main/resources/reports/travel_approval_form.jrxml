<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="travel_approval_form"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              whenResourceMissingType="Empty">

    <parameter name="formNumber" class="java.lang.String"/>
    <parameter name="applicantName" class="java.lang.String"/>
    <parameter name="pin" class="java.lang.String"/>
    <parameter name="designation" class="java.lang.String"/>
    <parameter name="program" class="java.lang.String"/>
    <parameter name="destination" class="java.lang.String"/>
    <parameter name="travelStartDateTime" class="java.lang.String"/>
    <parameter name="probableReturnDateTime" class="java.lang.String"/>
    <parameter name="purpose" class="java.lang.String"/>
    <parameter name="applicationDate" class="java.lang.String"/>
    <parameter name="applicantSignatureDate" class="java.lang.String"/>
    <parameter name="approverName" class="java.lang.String"/>
    <parameter name="approverPin" class="java.lang.String"/>
    <parameter name="approverDesignation" class="java.lang.String"/>
    <parameter name="generatedAt" class="java.lang.String"/>
    <parameter name="footerUrl" class="java.lang.String"/>
    <parameter name="footerUser" class="java.lang.String"/>
    <parameter name="bracLogoUrl" class="java.lang.String"/>

    <title>
        <band height="430" splitType="Stretch">

            <!-- Header: logo + form number -->
            <image scaleImage="RetainShape" onErrorType="Blank" hAlign="Left" vAlign="Top">
                <reportElement x="0" y="0" width="124" height="38"/>
                <imageExpression><![CDATA[$P{bracLogoUrl}]]></imageExpression>
            </image>
            <textField isBlankWhenNull="true">
                <reportElement x="360" y="2" width="195" height="16"/>
                <textElement textAlignment="Right">
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Form : " + $P{formNumber}]]></textFieldExpression>
            </textField>

            <!-- Title -->
            <staticText>
                <reportElement x="0" y="44" width="555" height="22"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true" fontName="DejaVu Serif"/>
                </textElement>
                <text><![CDATA[TRAVEL APPROVAL FORM]]></text>
            </staticText>

            <!-- Applicant / trip details — left column -->
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="82" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Name: " + $P{applicantName}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="102" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Program: " + $P{program}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="122" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Travel start date time: " + $P{travelStartDateTime}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="142" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Purpose: " + $P{purpose}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="162" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Application Date: " + $P{applicationDate}]]></textFieldExpression>
            </textField>

            <!-- Applicant / trip details — right column -->
            <textField isBlankWhenNull="true">
                <reportElement x="280" y="82" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["PIN: " + $P{pin}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="280" y="102" width="275" height="32"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Designation: " + $P{designation}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="280" y="138" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Destination: " + $P{destination}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="280" y="158" width="275" height="16"/>
                <textElement>
                    <font size="11" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA["Probable return date time: " + $P{probableReturnDateTime}]]></textFieldExpression>
            </textField>

            <!-- Signature / approval box -->
            <frame>
                <reportElement x="0" y="195" width="555" height="108"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#000000"/>
                </box>

                <line>
                    <reportElement x="277" y="0" width="1" height="108"/>
                    <graphicElement>
                        <pen lineWidth="0.5" lineColor="#000000"/>
                    </graphicElement>
                </line>

                <!-- Left: applicant signature -->
                <textField isBlankWhenNull="true">
                    <reportElement x="10" y="12" width="255" height="16"/>
                    <textElement>
                        <font size="11" fontName="DejaVu Serif"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Applicant Signature: " + $P{applicantName}]]></textFieldExpression>
                </textField>
                <textField isBlankWhenNull="true">
                    <reportElement x="10" y="32" width="255" height="16"/>
                    <textElement>
                        <font size="11" fontName="DejaVu Serif"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Date: " + $P{applicantSignatureDate}]]></textFieldExpression>
                </textField>

                <!-- Right: approval information -->
                <staticText>
                    <reportElement x="287" y="12" width="258" height="16"/>
                    <textElement>
                        <font size="11" isBold="true" fontName="DejaVu Serif"/>
                    </textElement>
                    <text><![CDATA[Approval information :]]></text>
                </staticText>
                <textField isBlankWhenNull="true">
                    <reportElement x="287" y="32" width="258" height="16"/>
                    <textElement>
                        <font size="11" fontName="DejaVu Serif"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Name: " + $P{approverName}]]></textFieldExpression>
                </textField>
                <textField isBlankWhenNull="true">
                    <reportElement x="287" y="52" width="258" height="16"/>
                    <textElement>
                        <font size="11" fontName="DejaVu Serif"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Pin: " + $P{approverPin}]]></textFieldExpression>
                </textField>
                <textField isBlankWhenNull="true">
                    <reportElement x="287" y="72" width="258" height="16"/>
                    <textElement>
                        <font size="11" fontName="DejaVu Serif"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Designation: " + $P{approverDesignation}]]></textFieldExpression>
                </textField>
            </frame>

            <!-- Post-trip completion box -->
            <frame>
                <reportElement x="0" y="308" width="555" height="82"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#000000"/>
                </box>

                <staticText>
                    <reportElement x="0" y="10" width="555" height="16"/>
                    <textElement textAlignment="Center">
                        <font size="11" isBold="true" fontName="DejaVu Serif"/>
                    </textElement>
                    <text><![CDATA[To be completed at the end of the trip]]></text>
                </staticText>
                <staticText>
                    <reportElement x="10" y="34" width="535" height="16"/>
                    <textElement>
                        <font size="11" fontName="DejaVu Serif"/>
                    </textElement>
                    <text><![CDATA[Actual return date: .................................................................... Time: ....................................................................]]></text>
                </staticText>
                <staticText>
                    <reportElement x="10" y="56" width="535" height="16"/>
                    <textElement>
                        <font size="11" fontName="DejaVu Serif"/>
                    </textElement>
                    <text><![CDATA[Reason if probable return date changes: .................................................................................................................]]></text>
                </staticText>
            </frame>

            <!-- Disclaimer -->
            <staticText>
                <reportElement x="0" y="400" width="555" height="14"/>
                <textElement>
                    <font size="10" fontName="DejaVu Serif"/>
                </textElement>
                <text><![CDATA[* This is a computer generated copy based on online approval]]></text>
            </staticText>
        </band>
    </title>

    <detail>
        <band height="1" splitType="Stretch"/>
    </detail>

    <pageFooter>
        <band height="20">
            <textField isBlankWhenNull="true" isStretchWithOverflow="true">
                <reportElement x="0" y="2" width="240" height="14"/>
                <textElement>
                    <font size="8" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{footerUrl}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="240" y="2" width="150" height="14"/>
                <textElement textAlignment="Center">
                    <font size="9" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{generatedAt}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="390" y="2" width="165" height="14"/>
                <textElement textAlignment="Right">
                    <font size="9" fontName="DejaVu Serif"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{footerUser}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
